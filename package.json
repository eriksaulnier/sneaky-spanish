{
  "name": "sneaky-spanish",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:firefox": "vite build --mode firefox",
    "package": "web-ext build --source-dir dist",
    "generate-dict": "tsx scripts/generate-dictionary.ts",
    "generate-icon": "tsx scripts/generate-icon.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-web-extension": "^4.5.0",
    "vitest": "^4.1.2",
    "web-ext": "^10.1.0"
  }
}
